{
  "name": "twy",
  "private": true,
  "version": "0.0.0",
  "description": "TWY monorepo",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "turbo run test",
    "dev": "sst dev",
    "dev:dashboard": "pnpm --filter @twy/dashboard dev",
    "deploy": "sst deploy",
    "remove": "sst remove",
    "shell": "sst shell",
    "run:dashboard": "pnpm --filter @twy/dashboard dev",
    "migrate": "sst shell -- pnpm --filter @twy/db migrate",
    "lint:commit": "commitlint --edit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/format": "^19.8.1",
    "@types/aws-lambda": "^8.10.155",
    "@types/node": "^24.0.0",
    "conventional-changelog-atom": "^5.0.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "sst": "^4.12.11",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
