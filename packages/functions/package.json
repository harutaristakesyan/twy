{
  "name": "@twy/functions",
  "version": "1.0.0",
  "description": "Lambda handlers (HTTP API + Cognito triggers) and Lambda-runtime middleware",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@middy/core": "^7.3.3",
    "@middy/event-normalizer": "^7.3.3",
    "@middy/http-error-handler": "^7.3.3",
    "@middy/http-event-normalizer": "^7.3.3",
    "@middy/http-json-body-parser": "^7.3.3",
    "@twy/core": "workspace:*",
    "@twy/db": "workspace:*",
    "@twy/email": "workspace:*",
    "axios": "^1.15.2",
    "http-errors": "^2.0.0",
    "http-status-codes": "^2.3.0",
    "sst": "^4.12.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^24.7.0",
    "esbuild": "^0.28.0"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT"
}
