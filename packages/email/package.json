{
  "name": "@twy/email",
  "version": "0.1.0",
  "description": "React Email templates and SES sending wrapper for TWY",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "lint-staged": {
    "*.{js,ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1045.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@types/react": "^19.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
