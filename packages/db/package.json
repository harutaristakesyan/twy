{
  "name": "@twy/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle schema, query operations, and migration runner for the Aurora Serverless v2 cluster.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "drizzle"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "migrate": "tsx ./src/migration/run-migrations.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-rds-data": "^3.1038.0",
    "drizzle-orm": "^0.44.6",
    "http-errors": "^2.0.0",
    "sst": "^4.12.11"
  },
  "devDependencies": {
    "@types/http-errors": "^2.0.5",
    "@types/node": "^24.7.0",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.6"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
