{
  "name": "@twy/lambda-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Lambda middlewares and helpers (middy wrappers, error utils)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@middy/core": "^7.3.3",
    "@middy/http-json-body-parser": "^7.3.3",
    "aws-cdk-lib": "^2.251.0",
    "http-errors": "^2.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^24.7.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
