{
  "name": "@twy/core",
  "version": "0.1.0",
  "description": "Runtime-agnostic business logic: domain schemas, repositories, services",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/lib-dynamodb": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@twy/db": "workspace:*",
    "drizzle-orm": "^0.44.6",
    "http-errors": "^2.0.0",
    "sst": "^4.12.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/http-errors": "^2.0.5",
    "@types/node": "^24.7.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
