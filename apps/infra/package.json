{
  "name": "@twy/infra",
  "version": "1.0.0",
  "description": "Infrastructure as code for TWY using AWS CDK",
  "private": true,
  "scripts": {
    "build": "tsc",
    "bootstrap": "ts-node bin/bootstrap.ts",
    "synth": "pnpm run build && pnpm exec cdk synth --context env=$ENV",
    "diff": "pnpm run build && pnpm exec cdk diff --context env=$ENV",
    "deploy": "pnpm run build && pnpm exec cdk deploy --require-approval never --context env=$ENV",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1038.0",
    "@aws-sdk/client-ssm": "^3.1038.0",
    "@aws-sdk/dsql-signer": "^3.1038.0",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.0.0",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.7.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT"
}
