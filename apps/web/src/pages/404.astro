---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — twy" description="Page not found">
  <div class="flex min-h-full flex-col items-center justify-center px-6 text-center">
    <p class="text-sm font-semibold text-gray-500">404</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900">
      Page not found
    </h1>
    <p class="mt-2 text-base text-gray-500">
      The page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-gray-700"
    >
      Go home
    </a>
  </div>
</BaseLayout>
