{
  "name": "@twy/functions",
  "version": "1.0.0",
  "description": "Business-logic Lambda functions and DB migrations",
  "private": true,
  "scripts": {
    "build": "tsc",
    "synth": "pnpm exec cdk synth",
    "diff": "pnpm exec cdk diff",
    "deploy": "pnpm exec cdk deploy --require-approval never",
    "migrate": "ts-node -P tsconfig.scripts.json -r tsconfig-paths/register ./src/migration/run-migrations.ts",
    "lint": "eslint . --ext .ts,.js --report-unused-disable-directives",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/client-ssm": "^3.1038.0",
    "@aws-sdk/dsql-signer": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@middy/core": "^6.4.5",
    "@middy/event-normalizer": "^6.4.5",
    "@middy/http-error-handler": "^6.4.5",
    "@middy/http-event-normalizer": "^6.4.5",
    "@middy/http-json-body-parser": "^6.4.5",
    "@twy/lambda-shared": "workspace:*",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.0.0",
    "axios": "^1.12.2",
    "http-errors": "^2.0.0",
    "http-status-codes": "^2.3.0",
    "kysely": "^0.28.8",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^22.18.1",
    "@types/pg": "^8.15.5",
    "esbuild": "^0.25.10",
    "eslint": "^9.34.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-sql": "^3.2.2",
    "globals": "^16.3.0",
    "typescript-eslint": "^8.42.0"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
