{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "paths": {
      "@contracts/*": ["./src/contracts/*"],
      "@functions/*": ["./src/functions/*"],
      "@libs/*": ["./src/libs/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
